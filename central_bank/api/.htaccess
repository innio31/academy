# /central_bank/api/.htaccess
# Prevent redirects that break CORS

RewriteEngine On

# Force HTTPS (but handle CORS properly)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Handle OPTIONS method
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Set CORS headers
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "https://www.acad.com.ng"
    Header set Access-Control-Allow-Origin "https://acad.com.ng"
    Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header set Access-Control-Allow-Headers "X-API-Key, Content-Type, Authorization, Accept"
    Header set Access-Control-Allow-Credentials "true"
    Header set Access-Control-Max-Age "86400"
</IfModule>